{
  "name": "TinphanPortfolio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint:ts": "tsx",
    "lint:scss": "stylelint \"**/*.scss\"",
    "lint": "npm run lint:ts && npm run lint:scss",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:regression": "npx chromatic",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "description": "A Feature‑Sliced, themeable front‑end foundation template — built with React, TypeScript and Vite. This repository demonstrates internationalization (i18n), reusable UI primitives, Storybook-driven component development, unit tests (Vitest), and CI visual regression.",
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "@testing-library/jest-dom": "^6.9.1",
    "axios": "^1.13.5",
    "i18next": "^25.8.4",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.4",
    "react-redux": "^9.2.0",
    "react-router": "^7.13.0",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@conarti/eslint-plugin-feature-sliced": "^1.0.5",
    "@eslint/js": "^9.39.0",
    "@storybook/addon-a11y": "^10.2.8",
    "@storybook/addon-controls": "^9.0.8",
    "@storybook/addon-docs": "^10.2.8",
    "@storybook/addon-onboarding": "^10.2.8",
    "@storybook/addon-vitest": "^10.2.8",
    "@storybook/react-vite": "^10.2.8",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "chromatic": "^15.1.0",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.0",
    "eslint-plugin-storybook": "^10.2.8",
    "globals": "^17.3.0",
    "i18next-cli": "^1.42.6",
    "jsdom": "^28.0.0",
    "playwright": "^1.58.2",
    "sass": "^1.73.1",
    "storybook": "^10.2.8",
    "stylelint": "^17.3.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-scss": "^7.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.55.0",
    "vite": "^7.3.1",
    "vite-plugin-svgr": "^4.5.0",
    "vitest": "^4.0.18"
